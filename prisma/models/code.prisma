model Code {
    id         Int      @id @default(autoincrement())
    code       String
    retryDate  DateTime @map("retry_date")
    expiryDate DateTime @map("expiry_date")
    userId     Int      @map("user_id")
    user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("codes")
}