// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Role {
    id    Int    @id @default(autoincrement())
    name  String
    users User[]

    @@map("roles")
}

model Token {
    token      String   @unique
    expiryDate DateTime @map("expiry_date")
    user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId     Int      @map("user_id")
    userAgent  String   @map("user_agent")

    @@map("tokens")
}

model Code {
    id         Int      @id @default(autoincrement())
    code       String
    retryDate  DateTime @map("retry_date")
    expiryDate DateTime @map("expiry_date")
    user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId     Int      @map("user_id")

    @@map("codes")
}

model User {
    id           Int           @id @default(autoincrement())
    email        String        @unique
    avatarKey    String?       @map("avatar_key")
    firstName    String?       @map("first_name")
    lastName     String?       @map("last_name")
    middleName   String?       @map("middle_name")
    birthDate    DateTime?     @map("birth_date")
    password     String?
    isVerified   Boolean       @default(false) @map("is_verified")
    createdAt    DateTime      @default(now()) @map("created_at")
    updatedAt    DateTime      @updatedAt @map("updated_at")
    roles        Role[]
    tokens       Token[]
    codes        Code[]
    invitedById  Int?          @map("invited_by_id")
    invitedBy    User?         @relation("UserInvitations", fields: [invitedById], references: [id])
    invitedUsers User[]        @relation("UserInvitations")
    inviteTokens InviteToken[]
    teams        Team[]
    ownedTeams   Team[]        @relation("TeamCreator")

    @@map("users")
}

model InviteToken {
    id        Int      @id @default(autoincrement())
    token     String   @unique
    creatorId Int      @map("creator_id")
    creator   User     @relation(fields: [creatorId], references: [id])
    createdAt DateTime @default(now()) @map("created_at")

    @@map("invite_tokens")
}

model Team {
    id        Int      @id @default(autoincrement())
    name      String
    logoKey   String?  @map("logo_key")
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    creatorId Int  @map("creator_id")
    creator   User @relation("TeamCreator", fields: [creatorId], references: [id])

    members User[]

    @@map("teams")
}
